{
  "version": 2,
  "name": "going-beta",
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/history/(.*)",
      "dest": "https://history.macaumarksix.com/history/macaujc2/y/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "github": {
    "silent": true,
    "autoJobCancelation": true
  }
}